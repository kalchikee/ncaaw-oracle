# NCAAW Oracle v4.1 — Environment Variables
# Copy this file to .env and fill in your values
# For GitHub Actions: add these as repository secrets

# Discord webhook URL (REQUIRED for Discord embeds)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# The Odds API key (optional — skip for predictions without Vegas lines)
# Free tier: 500 req/month — sufficient for daily WBB lines
# https://the-odds-api.com
ODDS_API_KEY=

# Database path (optional — defaults to ./data/oracle.sqlite)
DB_PATH=./data/oracle.sqlite

# Log level: debug | info | warn | error
LOG_LEVEL=info
